# ─── Credenciais SMTP (servidor de envio de e-mail) ───
# Para desenvolvimento, use uma conta gratuita do https://ethereal.email
# Para produção, use Gmail (Senha de App) ou outro provedor SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ─── Destinatário das mensagens do formulário ───
CONTACT_EMAIL=

# ─── CORS ───
# Em produção, coloque a URL do site na Netlify (ex.: https://mullertech.netlify.app)
# Em desenvolvimento, pode deixar vazio.
ALLOWED_ORIGIN=

# ─── reCAPTCHA v2 Checkbox ───
# Gere as chaves em https://www.google.com/recaptcha/admin (registre o domínio do
# site + localhost). VITE_RECAPTCHA_SITE_KEY é pública (vai no frontend, build-time);
# RECAPTCHA_SECRET é secreta (usada na function para validar o token).
VITE_RECAPTCHA_SITE_KEY=sua-site-key
RECAPTCHA_SECRET=sua-secret-key
