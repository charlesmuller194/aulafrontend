# ─── Credenciais SMTP (servidor de envio de e-mail) ───
# Para desenvolvimento, use uma conta gratuita do https://ethereal.email
# Para produção, use Gmail (Senha de App) ou outro provedor SMTP.
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-usuario-smtp
SMTP_PASS=sua-senha-smtp

# ─── Destinatário das mensagens do formulário ───
CONTACT_EMAIL=contato@mullertech.com.br

# ─── CORS ───
# Em produção, coloque a URL do site na Netlify (ex.: https://mullertech.netlify.app)
# Em desenvolvimento, pode deixar vazio.
ALLOWED_ORIGIN=
